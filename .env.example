# Device Bridge configuration. Copy to `.env` and adjust. All optional in Phase 2.

# Where raw captured HL7 messages are written (default: ./logs)
# LOG_DIR=/var/log/device-bridge

# Values placed in the ACK we send back to the analyzer (cosmetic)
ACK_APP=NIZOMED_EHR
ACK_FACILITY=LAB

# --- Phase 3 (not used yet) ---
# Where parsed results will be POSTed. Offline LAN facility uses the local
# ehr-servers. MUST be 127.0.0.1 (never "localhost") on an offline server.
# EHR_INGEST_URL=http://127.0.0.1:6090/lab/device-results/ingest
# Shared secret mirroring the proxy handshake, so only trusted local processes
# can write results.
# SECURITY_KEY=
